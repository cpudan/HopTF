\newlabel{tab:matched_retrieval_change}{{7}{23}{Matched retrieval-change diagnostic. Positive paired differences mean pathogenic variants moved the retrieval distribution more than the matched control group.\relax }{table.caption.22}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Variant-specific retrieval movement across \textsc  {AlphaGenome}\ key entries. Each chromosome is split into visualization bins for the retrieved gene-associated entries used by \textsc  {HopTF}. The panels show wild type, pathogenic mutant, matched benign/control sequence, and pathogenic minus wild type change for selected examples. These are retrieval weights over candidate regulatory-context entries, not measured binding sites.\relax }}{23}{figure.caption.23}\protected@file@percent }
\newlabel{fig:variant_retrieval_chromosome_heatmap}{{10}{23}{Variant-specific retrieval movement across \ag \ key entries. Each chromosome is split into visualization bins for the retrieved gene-associated entries used by \hoptf . The panels show wild type, pathogenic mutant, matched benign/control sequence, and pathogenic minus wild type change for selected examples. These are retrieval weights over candidate regulatory-context entries, not measured binding sites.\relax }{figure.caption.23}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.6}\(\beta \) controls retrieval regime}{23}{subsection.6.6}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces \(\beta \) controls retrieval concentration. Effective loci and top-100 mass are medians across TF rows.\relax }}{24}{table.caption.24}\protected@file@percent }
\newlabel{tab:beta_sensitivity}{{8}{24}{\(\beta \) controls retrieval concentration. Effective loci and top-100 mass are medians across TF rows.\relax }{table.caption.24}{}}
\citation{rauluseviciute2024jaspar}
\citation{hammal2022remap}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Effect of retrieval inverse temperature \(\beta \). Increasing \(\beta \) shifts retrieval from diffuse averaging over many \textsc  {AlphaGenome}\ key entries toward more focused use of a smaller subset, while adjacent \(\beta \) values preserve the same top-ranked entries. Independent motif and ReMap support remains weak across the sweep. The \(\beta \) result supports controllable associative retrieval behavior and a biologically interpretable sensitivity parameter, not dose-calibrated TF concentration or validated binding-site discovery.\relax }}{25}{figure.caption.25}\protected@file@percent }
\newlabel{fig:beta_sweep}{{11}{25}{Effect of retrieval inverse temperature \(\beta \). Increasing \(\beta \) shifts retrieval from diffuse averaging over many \ag \ key entries toward more focused use of a smaller subset, while adjacent \(\beta \) values preserve the same top-ranked entries. Independent motif and ReMap support remains weak across the sweep. The \(\beta \) result supports controllable associative retrieval behavior and a biologically interpretable sensitivity parameter, not dose-calibrated TF concentration or validated binding-site discovery.\relax }{figure.caption.25}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.7}Motif and ReMap support remains limited under exact matching}{25}{subsection.6.7}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces Motif and ReMap recall remains limited under exact TF symbol matching; stronger validation with accessibility support and matched background windows remains pending.\relax }}{26}{table.caption.26}\protected@file@percent }
\newlabel{tab:motif_results}{{9}{26}{Motif and ReMap recall remains limited under exact TF symbol matching; stronger validation with accessibility support and matched background windows remains pending.\relax }{table.caption.26}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Recall of exact motif and ReMap support among 1\nobreakspace  {}kb validation windows associated with top retrieved entries. Recall remains near or below the value expected if the retrieval ranking were random at the current validation-window scale, so this result should be interpreted as a limitation rather than positive binding validation.\relax }}{27}{figure.caption.27}\protected@file@percent }
\newlabel{fig:motif_binding_recall_by_topk}{{12}{27}{Recall of exact motif and ReMap support among 1~kb validation windows associated with top retrieved entries. Recall remains near or below the value expected if the retrieval ranking were random at the current validation-window scale, so this result should be interpreted as a limitation rather than positive binding validation.\relax }{figure.caption.27}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Motif and ReMap support among 1\nobreakspace  {}kb validation windows associated with top retrieved entries. This diagnostic asks what fraction of retrieved-entry validation windows have exact TF symbol support; it remains modest and motivates validation that relaxes exact symbol matching where biologically justified and incorporates accessibility support.\relax }}{28}{figure.caption.28}\protected@file@percent }
\newlabel{fig:motif_binding_precision_by_topk}{{13}{28}{Motif and ReMap support among 1~kb validation windows associated with top retrieved entries. This diagnostic asks what fraction of retrieved-entry validation windows have exact TF symbol support; it remains modest and motivates validation that relaxes exact symbol matching where biologically justified and incorporates accessibility support.\relax }{figure.caption.28}{}}
