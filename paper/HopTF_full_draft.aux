\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Overview of \textsc  {HopTF}. A TF isoform amino-acid sequence is encoded into a protein query, gene-associated \textsc  {AlphaGenome}\ embeddings provide a memory bank of locus keys and values, and associative retrieval produces a weighted regulatory-context representation \(\mu _p\). This retrieved context conditions a flow model that predicts transport from unperturbed to TF-perturbed cell states. Retrieval weights are interpreted as candidate regulatory-context hypotheses rather than validated binding sites.\relax }}{3}{figure.caption.3}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:overview}{{1}{3}{Overview of \hoptf . A TF isoform amino-acid sequence is encoded into a protein query, gene-associated \ag \ embeddings provide a memory bank of locus keys and values, and associative retrieval produces a weighted regulatory-context representation \(\mu _p\). This retrieved context conditions a flow model that predicts transport from unperturbed to TF-perturbed cell states. Retrieval weights are interpreted as candidate regulatory-context hypotheses rather than validated binding sites.\relax }{figure.caption.3}{}}
