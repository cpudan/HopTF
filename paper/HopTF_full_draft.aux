\@writefile{toc}{\contentsline {subsection}{\numberline {6.1}Predicting the state of the perturbed cell}{15}{subsection.6.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Experiment 1 prediction of the perturbed-cell state on grouped held-out-gene splits. Lower MSE is better.\relax }}{15}{table.caption.12}\protected@file@percent }
\newlabel{tab:perturbed_state_results}{{3}{15}{Experiment 1 prediction of the perturbed-cell state on grouped held-out-gene splits. Lower MSE is better.\relax }{table.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces MSE for predicting the perturbed-cell state. The \textsc  {ESM-C}-derived representation after projection into \textsc  {AlphaGenome}\ key space modestly improves over using only protein length, ORF length, and recovered cell count. \textsc  {ESM-DBP}\ does not improve this benchmark.\relax }}{16}{figure.caption.13}\protected@file@percent }
\newlabel{fig:experiment1_controlled_overall_mse}{{4}{16}{MSE for predicting the perturbed-cell state. The \esm -derived representation after projection into \ag \ key space modestly improves over using only protein length, ORF length, and recovered cell count. \esmdbp \ does not improve this benchmark.\relax }{figure.caption.13}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}Ablation studies}{16}{subsection.6.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Overall encoder ablation. Percent change is relative to using only protein length, ORF length, and recovered cell count. Negative values indicate lower MSE.\relax }}{16}{table.caption.14}\protected@file@percent }
\newlabel{tab:ablation_results}{{4}{16}{Overall encoder ablation. Percent change is relative to using only protein length, ORF length, and recovered cell count. Negative values indicate lower MSE.\relax }{table.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces MSE change after adding sequence features to a model that already uses protein length, ORF length, and recovered cell count. \textsc  {ESM-C}\ projected into \textsc  {AlphaGenome}\ key space modestly improves in protein-length groups, recovered-cell-count groups, and joint length-plus-cell-count groups; \textsc  {ESM-DBP}\ is worse in the same comparisons.\relax }}{17}{figure.caption.15}\protected@file@percent }
\newlabel{fig:experiment1_sequence_after_length_cell_count}{{5}{17}{MSE change after adding sequence features to a model that already uses protein length, ORF length, and recovered cell count. \esm \ projected into \ag \ key space modestly improves in protein-length groups, recovered-cell-count groups, and joint length-plus-cell-count groups; \esmdbp \ is worse in the same comparisons.\relax }{figure.caption.15}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.3}SCARF response representation and controlled sequence benchmark}{17}{subsection.6.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces \textsc  {SCARF}-space controlled sequence benchmark. Lower MSE is better. Percent change is relative to the model using protein length, ORF length, and recovered cell count.\relax }}{18}{table.caption.16}\protected@file@percent }
\newlabel{tab:scarf_sequence_benchmark}{{5}{18}{\scarf -space controlled sequence benchmark. Lower MSE is better. Percent change is relative to the model using protein length, ORF length, and recovered cell count.\relax }{table.caption.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textsc  {SCARF}-space controlled sequence-feature benchmark. Protein length, ORF length, and recovered cell count are difficult to beat; adding the Hopfield query or \textsc  {ESM-C}\ features does not improve held-out-gene prediction in this response representation.\relax }}{18}{figure.caption.17}\protected@file@percent }
\newlabel{fig:scarf_sequence_feature_benchmark}{{6}{18}{\scarf -space controlled sequence-feature benchmark. Protein length, ORF length, and recovered cell count are difficult to beat; adding the Hopfield query or \esm \ features does not improve held-out-gene prediction in this response representation.\relax }{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Matched-context \textsc  {SCARF}-space sequence benchmark. The heatmap diagnoses whether sequence features help after stratifying by protein length, recovered cell count, or both; in this run, the sequence-feature additions do not improve over the measured covariates.\relax }}{18}{figure.caption.18}\protected@file@percent }
\newlabel{fig:scarf_sequence_improvement_heatmap}{{7}{18}{Matched-context \scarf -space sequence benchmark. The heatmap diagnoses whether sequence features help after stratifying by protein length, recovered cell count, or both; in this run, the sequence-feature additions do not improve over the measured covariates.\relax }{figure.caption.18}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.4}Missense variants perturb predicted TF response}{19}{subsection.6.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces \textsc  {SCARF}-space matched variant validation. Positive paired differences mean pathogenic variants changed predicted perturbed-cell state activity more than the matched control group.\relax }}{19}{table.caption.19}\protected@file@percent }
\newlabel{tab:matched_variant_validation}{{6}{19}{\scarf -space matched variant validation. Positive paired differences mean pathogenic variants changed predicted perturbed-cell state activity more than the matched control group.\relax }{table.caption.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Absolute predicted perturbed-cell state activity change for pathogenic variants versus matched controls. This is the primary variant-sensitivity framing because damaging TF variants may weaken, strengthen, or redirect predicted response rather than only reducing response magnitude.\relax }}{20}{figure.caption.20}\protected@file@percent }
\newlabel{fig:absolute_variant_effect_violin}{{8}{20}{Absolute predicted perturbed-cell state activity change for pathogenic variants versus matched controls. This is the primary variant-sensitivity framing because damaging TF variants may weaken, strengthen, or redirect predicted response rather than only reducing response magnitude.\relax }{figure.caption.20}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Signed predicted perturbed-cell state activity change for pathogenic variants versus matched controls. This diagnostic shows why the paper does not claim a consistent signed weakening effect: pathogenic variants are not expected to move responses in one direction only.\relax }}{21}{figure.caption.21}\protected@file@percent }
\newlabel{fig:signed_variant_effect_violin}{{9}{21}{Signed predicted perturbed-cell state activity change for pathogenic variants versus matched controls. This diagnostic shows why the paper does not claim a consistent signed weakening effect: pathogenic variants are not expected to move responses in one direction only.\relax }{figure.caption.21}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.5}Variant effects move the retrieval distribution}{21}{subsection.6.5}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Matched retrieval-change diagnostic. Positive paired differences mean pathogenic variants moved the retrieval distribution more than the matched control group.\relax }}{22}{table.caption.22}\protected@file@percent }
\newlabel{tab:matched_retrieval_change}{{7}{22}{Matched retrieval-change diagnostic. Positive paired differences mean pathogenic variants moved the retrieval distribution more than the matched control group.\relax }{table.caption.22}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Variant-specific retrieval movement across \textsc  {AlphaGenome}\ windows. Each chromosome is split into the locus bins used by HopTF. The panels show wild type, pathogenic mutant, matched benign/control sequence, and pathogenic-minus-WT change for selected examples. These are locus-window retrieval weights, not measured binding sites.\relax }}{22}{figure.caption.23}\protected@file@percent }
\newlabel{fig:variant_retrieval_chromosome_heatmap}{{10}{22}{Variant-specific retrieval movement across \ag \ windows. Each chromosome is split into the locus bins used by HopTF. The panels show wild type, pathogenic mutant, matched benign/control sequence, and pathogenic-minus-WT change for selected examples. These are locus-window retrieval weights, not measured binding sites.\relax }{figure.caption.23}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.6}Beta controls retrieval regime}{22}{subsection.6.6}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Beta controls retrieval concentration. Effective loci and top-100 mass are medians across TF rows.\relax }}{23}{table.caption.24}\protected@file@percent }
\newlabel{tab:beta_sensitivity}{{8}{23}{Beta controls retrieval concentration. Effective loci and top-100 mass are medians across TF rows.\relax }{table.caption.24}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Effect of retrieval inverse temperature \(\beta \). Increasing \(\beta \) concentrates retrieval mass onto fewer \textsc  {AlphaGenome}\ windows while the identities of the highest-ranked windows remain stable across adjacent beta values. This supports the associative-retrieval interpretation but does not test beta-resolved \textsc  {SCARF}-space prediction quality.\relax }}{23}{figure.caption.25}\protected@file@percent }
\newlabel{fig:beta_sweep}{{11}{23}{Effect of retrieval inverse temperature \(\beta \). Increasing \(\beta \) concentrates retrieval mass onto fewer \ag \ windows while the identities of the highest-ranked windows remain stable across adjacent beta values. This supports the associative-retrieval interpretation but does not test beta-resolved \scarf -space prediction quality.\relax }{figure.caption.25}{}}
