\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Interpretable activation patterns over loci. Plot to create. Genome browser-style track or Manhattan-like plot showing retrieval weights over loci for selected TFs and cell-state clusters. Add tracks for accessibility, motif hits, nearby genes, and observed expression changes if available.\relax }}{24}{figure.caption.27}\protected@file@percent }
\newlabel{fig:retrieval_tracks}{{12}{24}{Interpretable activation patterns over loci. Plot to create. Genome browser-style track or Manhattan-like plot showing retrieval weights over loci for selected TFs and cell-state clusters. Add tracks for accessibility, motif hits, nearby genes, and observed expression changes if available.\relax }{figure.caption.27}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.8}Motif enrichment and external binding validation}{24}{subsection.6.8}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces Current exact-symbol motif and binding recall is weak; redesigned family-level and accessibility-supported validation remains pending.\relax }}{25}{table.caption.28}\protected@file@percent }
\newlabel{tab:motif_results}{{10}{25}{Current exact-symbol motif and binding recall is weak; redesigned family-level and accessibility-supported validation remains pending.\relax }{table.caption.28}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Recall of exact-symbol motif and ReMap support among top-ranked retrieved windows. Recall remains near or below random-rank expectation at the current \textsc  {AlphaGenome}-window scale, so this result should be interpreted as a limitation rather than positive binding validation.\relax }}{25}{figure.caption.29}\protected@file@percent }
\newlabel{fig:motif_binding_recall_by_topk}{{13}{25}{Recall of exact-symbol motif and ReMap support among top-ranked retrieved windows. Recall remains near or below random-rank expectation at the current \ag -window scale, so this result should be interpreted as a limitation rather than positive binding validation.\relax }{figure.caption.29}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces Precision-style motif and ReMap support among top-ranked retrieved windows. This diagnostic asks what fraction of retrieved windows have exact same-symbol support; it remains modest and motivates family-level, alias-aware, and accessibility-supported validation.\relax }}{26}{figure.caption.30}\protected@file@percent }
\newlabel{fig:motif_binding_precision_by_topk}{{14}{26}{Precision-style motif and ReMap support among top-ranked retrieved windows. This diagnostic asks what fraction of retrieved windows have exact same-symbol support; it remains modest and motivates family-level, alias-aware, and accessibility-supported validation.\relax }{figure.caption.30}{}}
